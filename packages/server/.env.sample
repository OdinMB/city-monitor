# City Monitor — Server Environment Variables
# Copy this file to .env and fill in your values.

# Active cities (comma-separated city IDs)
ACTIVE_CITIES=berlin

# PostgreSQL connection string (required when DB persistence is wired)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/city_monitor

# OpenAI API key for AI news summaries (optional — summaries disabled without it)
# OPENAI_API_KEY=sk-...

# OpenAI model override (default: gpt-4.1-mini)
# OPENAI_MODEL=gpt-4.1-mini

# Server port (default: 3001)
# PORT=3001

# TomTom API key for traffic data (optional — traffic disabled without it)
TOMTOM_API_KEY=
# City Monitor — Environment Variables
# Copy to .env and fill in values.

# ── Required ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/city_monitor
OPENAI_API_KEY=sk-...

# ── Optional (server) ────────────────────────────────────
# Comma-separated city IDs to activate (default: berlin)
ACTIVE_CITIES=berlin,hamburg

# CORS allowed origins (default: https://citymonitor.app)
ALLOWED_ORIGINS=https://citymonitor.app

# Port for the Express server (default: 3001)
PORT=3001

# ── API keys (optional, features degrade gracefully) ─────
# OpenWeatherMap — weather tile proxy
OPENWEATHERMAP_API_KEY=

# Firecrawl — appointment scraping (Berlin)
FIRECRAWL_API_KEY=

# LocationIQ — geocoding fallback
LOCATIONIQ_TOKEN=

# WAQI — air quality grid
WAQI_API_TOKEN=

# TomTom — traffic incidents
TOMTOM_API_KEY=

# Ticketmaster — event discovery
TICKETMASTER_CONSUMER_KEY=

# ── AI model overrides ───────────────────────────────────
# Summarization model (default: gpt-5-mini)
OPENAI_MODEL=gpt-5-mini

# Headline classifier model (default: gpt-5-nano)
OPENAI_FILTER_MODEL=gpt-5-nano
